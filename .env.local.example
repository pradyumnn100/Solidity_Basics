# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Your deployed FundMe contract address on Sepolia
NEXT_PUBLIC_FUNDME_ADDRESS=0xYourDeployedContractAddress

# Optional: shows a progress bar toward this ETH amount on the homepage.
# This is a purely cosmetic frontend target — it isn't enforced on-chain.
# Leave unset to hide the progress bar entirely.
NEXT_PUBLIC_FUNDING_GOAL_ETH=1
